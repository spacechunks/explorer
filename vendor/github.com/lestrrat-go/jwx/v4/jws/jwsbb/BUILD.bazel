load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "jwsbb",
    srcs = [
        "crypto_signer.go",
        "ecdsa.go",
        "eddsa.go",
        "format.go",
        "header.go",
        "hmac.go",
        "jwsbb.go",
        "rsa.go",
        "sign.go",
        "verify.go",
    ],
    importpath = "github.com/lestrrat-go/jwx/v4/jws/jwsbb",
    visibility = ["//visibility:public"],
    deps = [
        "//internal/base64",
        "//internal/ecutil",
        "//internal/keyconv",
        "//internal/tokens",
        "@com_github_lestrrat_go_dsig//:dsig",
        "@com_github_valyala_fastjson//:fastjson",
    ],
)

go_test(
    name = "jwsbb_test",
    srcs = [
        "header_test.go",
        "jwsbb_test.go",
    ],
    deps = [
        ":jwsbb",
        "//internal/base64",
        "//internal/pool",
        "@com_github_stretchr_testify//require",
    ],
)

alias(
    name = "go_default_library",
    actual = ":jwsbb",
    visibility = ["//visibility:public"],
)
